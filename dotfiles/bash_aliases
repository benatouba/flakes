    alias "qtipforcing=cd /sim/forcing_data/GCM/"
    alias "qtipgps=cd /local_data/gps/qtip/"
    alias idl="/usr/local/harris/idl87/bin/idl"
    alias config='/usr/bin/git --git-dir=$HOME/.cfg/ --work-tree=$HOME'
fi


alias mkdir="mkdir -pv"
alias svim="sudo vim -u $XDG_CONFIG_HOME/nvim/init.lua"
if [ $USER = "ben" ]
then
    # alias vim="~/.programs/nvim.appimage"
    alias vim="nvim"
    alias oni2="~/.programs/onivim2.appimage"
    alias upapt="sudo apt update && sudo apt upgrade -y && sudo apt autoremove && sudo apt clean && sudo apt autoclean"
    alias upconda="upcondabaseenv && upcondadashboardsenv"
    alias upvim="vim +PackerSync +UpdateRemotePlugins"
    alias upcondabaseenv="conda update -y -n base --file ~/.dotfiles/conda_base.yaml"
    alias upcondadashboardsenv="conda update -y -n dashboards --file ~/.dotfiles/conda_dashboards.yaml"
    alias upall="upapt && upconda && upvim"
    alias config="/usr/bin/git --git-dir=$HOME/.cfg/ --work-tree=$HOME"
    alias watchman_reset="watchman watch-del-all && watchman shutdown-server"
fi

if [ $USER = "schmidt" ]; then

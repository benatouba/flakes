{
  // Workspaces
  "hyprland/workspaces": {
    "on-scroll-up": "hyprctl dispatch workspace r-1",
    "on-scroll-down": "hyprctl dispatch workspace r+1",
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "format": "{}",
    "format-icons": {
      "urgent": "",
      "active": "",
      "default": ""
    },
    "persistent-workspaces": {
            "*": 2
    }
  },
  // Taskbar
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 18,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": [
      "Alacritty",
      "kitty"
    ],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    },
    "rewrite": {
      "Firefox Web Browser": "Firefox",
      "Foot Server": "Terminal"
    }
  },
  // Hyprland Window
  "hyprland/window": {
    "max-length": 60,
    "rewrite": {
      "(.*) - Brave": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Outlook": "$1",
      "(.*) Microsoft Teams": "$1"
    },
    "separate-outputs": true
  },
  // ML4W Welcome App
  "custom/ml4w-welcome": {
    "on-click": "flatpak run com.ml4w.sidebar",
    "format": " ",
    "tooltip-format": "Open ML4W Sidebar App"
  },
  // Empty
  "custom/empty": {
    "format": ""
  },
  // Tools
  "custom/tools": {
    "format": "ГЇВ—ВЅ",
    "tooltip-format": "Tools",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },

  // Now Playing
  "custom/nowplaying": {
    "exec": "~/.config/ml4w/scripts/ml4w-now-playing",
    "format": "ГЇВЂВЃ  {text}",
    "return-type": "json",
    "interval": 1,
    "escape": true,
    "hide-empty-text": false,
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-click-middle": "playerctl previous",
    "tooltip-format": "Left: Play/Pause\nRight: Next\nMiddle: Previous"
  },

  // Cliphist
  "custom/cliphist": {
    "format": "ГЇВѓВЄ",
    "on-click": "sleep 0.1 && ~/.config/ml4w/scripts/ml4w-cliphist",
    "on-click-right": "sleep 0.1 && ~/.config/ml4w/scripts/ml4w-cliphist d",
    "on-click-middle": "sleep 0.1 && ~/.config/ml4w/scripts/ml4w-cliphist w",
    "tooltip-format": "Left: Open clipboard Manager\nRight: Delete an entry\nMiddle: Clear list",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Updates Count
  "custom/updates": {
    "format": "ГЇВ†ВІ  {}",
    "escape": true,
    "return-type": "json",
    "exec": "~/.config/ml4w/scripts/ml4w-check-system-updates",
    "interval": 1800,
    "signal": 1,
    "hide-empty-text": true,
    "on-click": "~/.config/ml4w/settings/installupdates.sh"
  },
  // Wallpaper
  "custom/wallpaper": {
    "format": "ГЇВЂВѕ",
    "on-click": "bash -c waypaper &",
    "on-click-right": "~/.config/hypr/scripts/wallpaper-effects.sh",
    "tooltip-format": "Left: Select a wallpaper\nRight: Select wallpaper effect"
  },
  // Waybar Themes
  "custom/waybarthemes": {
    "format": "ГЇВ…ВЃ",
    "on-click": "~/.config/waybar/themeswitcher.sh",
    "tooltip-format": "Select a waybar theme"
  },
  // Settings
  "custom/settings": {
    "format": "ГЇВЂВ“",
    "on-click": "sleep 0.1 && com.ml4w.dotfilessettings",
    "tooltip-format": "ML4W Settings"
  },
  // Keybindings
  "custom/keybindings": {
    "format": "ГЇВ„Вњ",
    "on-click": "~/.config/hypr/scripts/keybindings.sh",
    "tooltip": false
  },
  // Calculator
  "custom/calculator": {
    "format": "ГЇВ‡В¬",
    "on-click": "qalculate-gtk",
    "tooltip-format": "Open calculator"
  },
  // Rofi Application Launcher
  "custom/appmenu": {
    // START APPS LABEL
    "format": "Apps",
    // END APPS LABEL
    "on-click": "~/.config/hypr/scripts/launcher.sh",
    "on-click-right": "~/.config/hypr/scripts/keybindings.sh",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings"
  },
  // Rofi Application Launcher
  "custom/appmenuicon": {
    "format": "ГЇВ„Вµ",
    "on-click": "sleep 0.2;rofi -show drun -replace",
    "on-click-right": "~/.config/hypr/scripts/keybindings.sh",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings"
  },
  // Power Menu
  "custom/exit": {
    "format": "ГЇВЂВ‘",
    "on-click": "~/.config/ml4w/scripts/ml4w-wlogout",
    "on-click-right": "hyprlock",
    "tooltip-format": "Left: Power menu\nRight: Lock screen"
  },
  // SwayNC
  "custom/notification": {
    "tooltip-format": "Left: Notifications\nRight: Do not disturb",
    "format": "{icon}",
    "format-icons": {
      "notification": "notifications_active",
      "none": "notifications",
      "dnd-notification": "notifications_active",
      "dnd-none": "notifications_paused",
      "inhibited-notification": "notification_important",
      "inhibited-none": "notification_important",
      "dnd-inhibited-notification": "notification_off",
      "dnd-inhibited-none": "notifications_off"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  // Hyprsunset
  "custom/hyprshade": {
    "format": "Г®В“Вњ",
    "tooltip-format": "Toggle Screen Shader",
    "on-click": "sleep 0.5; ~/.config/ml4w/scripts/ml4w-toggle-hyprsunset",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Hypridle inhibitor
  "custom/hypridle": {
    "format": "ГЇВЂВЈ",
    "return-type": "json",
    "escape": true,
    "exec-on-event": true,
    "interval": 60,
    "exec": "~/.config/hypr/scripts/hypridle.sh status",
    "on-click": "~/.config/hypr/scripts/hypridle.sh toggle",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Keyboard State
  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": "{name} {icon}",
    "format-icons": {
      "locked": "ГЇВЂВЈ",
      "unlocked": "ГЇВ‚Вњ"
    },
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // System tray
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },
  // Clock
  "clock": {
        "format": "{:%H:%M - %Od.%Om.%y}",
    "on-click": "flatpak run com.ml4w.calendar",
    "timezone": "",
    "tooltip": false
  },
  // System
  "custom/system": {
    "format": "Г®В‘Ві",
    "tooltip": false,
    "on-scroll-up": "true",
    "on-click": "wezterm start -- btop",
    "on-scroll-down": "true"
  },
  // CPU
  "cpu": {
    "format": "п’ј {usage}%",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Memory
  "memory": {
    "format": "ої… {}%",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Harddisc space used
  "disk": {
    "interval": 30,
    "format": "у°‹Љ {percentage_used}%",
    "path": "/",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  "hyprland/language": {
    "format": "/ K {short}",
    "on-click": "hyprctl switchxkblayout all next",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Group Hardware
  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/system",
      "disk",
      "cpu",
      "memory",
      "hyprland/language"
    ]
  },
  // Group Tools
  "group/tools": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/tools",
      "custom/cliphist",
      "custom/hypridle",
      "custom/hyprshade",
      "power-profiles-daemon"
    ]
  },
  // Group Links
  "group/links": {
    "orientation": "horizontal",
    "modules": [
      "custom/chatgpt",
      "custom/empty"
    ]
  },
  // Group Settings
  "group/settings": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": true
    },
    "modules": [
      "custom/settings",
      "custom/waybarthemes",
      "custom/wallpaper"
    ]
  },
  // Network
  "network": {
    "format": "{ifname}",
    "format-wifi": "ГЇВ‡В« {signalStrength}%",
    "format-ethernet": "ГЇВћВ–  {ifname}",
    "format-disconnected": "Disconnected ГўВљВ ",
    "tooltip-format": "ГЇВћВ– {ifname} via {gwaddri}",
    "tooltip-format-wifi": "ГЇВ‡В«  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
    "tooltip-format-ethernet": "ГЇВћВ– {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "nm-connection-editor",
    "on-click-right": "bash -c 'if nmcli radio wifi | grep -q enabled; then nmcli radio wifi off; else nmcli radio wifi on; fi'",
  },
  // Battery
  "battery": {
    "interval": 1,
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "ГЇВ—В§  {capacity}%",
    "format-plugged": "ГЇВ‡В¦  {capacity}%",
    "format-alt": "{icon}  {time}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": [
      "ГЇВ‰В„ ",
      "ГЇВ‰Вѓ ",
      "ГЇВ‰В‚ ",
      "ГЇВ‰ВЃ ",
      "ГЇВ‰ВЂ "
    ]
  },
  // Power Profiles Daemon
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "ГЇВ†В…",
      "performance": "ГЇВѓВ§",
      "balanced": "ГЇВЎВЈ",
      "power-saver": "ГЇВЃВ¬"
    },
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Pulseaudio
  "pulseaudio": {
    // "scroll-step": 1, // %, can be a float
    "format": "{icon} {volume}%",
    "format-bluetooth": "{volume}% у°¦ў {format_source}",
    "format-bluetooth-muted": "ГЇВљВ©  {format_source}",
    "format-muted": "ГЇВљВ© {format_source}",
    "format-source": "{volume}% ГЇВ„В°",
    "format-source-muted": "ГЇВ„В±",
    "format-icons": {
      "headphone": "ГЇВЂВҐ ",
      "hands-free": "ГЇВ–Вђ ",
      "headset": "ГЇВ–Вђ ",
      "phone": "ГЇВ‚В• ",
      "portable": "ГЇВ‚В• ",
      "car": "ГЇВ†В№ ",
      "default": [
        "ГЇВЂВ¦",
        "ГЇВЂВЁ",
        "ГЇВЂВЁ"
      ]
    },
    "on-click": "pavucontrol",
    "on-click-right": "pamixer -t",
    "tooltip-format": "Left: Volume control\nRight: Toggle mute"
  },
  // Bluetooth
  "bluetooth": {
    "format": "у°‚Ї ",
    "format-connected": "у°‚± {num_connections}",
    "format-disabled": "у°‚І ",
    "format-off": "у°‚І ",
    "interval": 30,
    "on-click": "blueman-manager",
    "on-click-right": "rfkill toggle bluetooth",
    "tooltip-format": "Bluetooth: {status}",
    "tooltip-format-connected": "{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_battery_percentage}%",
    "format-no-controller": ""
  },
  // Other
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },
  // backlight:
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "Г®ВЋВЌ",
      "Г®ВЏВ”",
      "Г®ВЏВ“",
      "Г®ВЏВ’",
      "Г®ВЏВ‘",
      "Г®ВЏВђ",
      "Г®ВЏВЏ",
      "Г®ВЏВЋ",
      "Г®ВЏВЌ",
      "Г®ВЏВЊ",
      "Г®ВЏВ‹",
      "Г®ВЏВЉ",
      "Г®ВЏВ‰",
      "Г®ВЏВ€",
      "Г®ВЋВ›"
    ],
    "scroll-step": 1
  }
}

{
	"layer": "top",
	"position": "top",
	"spacing": 4,
	"modules-left": [
		"hyprland/workspaces"
	],
	"modules-center": [
		"clock"
	],
	"modules-right": [
		"idle_inhibitor",
		"pulseaudio",
		"backlight",
		"cpu",
		"memory",
		"disk",
		"network",
		"bluetooth",
		"battery",
		"custom/notification",
		"hyprland/language",
		"tray",
		"custom/power"
	],
	"hyprland/workspaces": {
		"on-click": "activate",
		"on-scroll-up": "hyprctl dispatch workspace e-1",
		"on-scroll-down": "hyprctl dispatch workspace e+1",
		"format": "{icon}",
		"all-outputs": true,
		"format-icons": {
			"terminal": "",
			"web": "󰖟",
			"music": "󰝚",
			"email": "󰇮",
			"active": "",
			"default": "",
			"urgent": ""
		}
	},
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "󰅶",
			"deactivated": "󰾪"
		},
		"on-click-right": "hyprlock",
		"tooltip-format-activated": "Idle inhibitor: active (screen stays awake)",
		"tooltip-format-deactivated": "Idle inhibitor: inactive (will sleep on idle)"
	},
	"clock": {
		"tooltip-format": "<tt><small>{calendar}</small></tt>",
		"actions": {
			"on-click-right": "mode"
		},
		"calendar": {
			"mode": "year",
			"mode-mon-col": 3,
			"weeks-pos": "right",
			"on-scroll": 1,
			"format": {
				"months": "<span color='#ffead3'><b>{}</b></span>",
				"days": "<span color='#ecc6d9'><b>{}</b></span>",
				"weeks": "<span color='#99ffdd'><b>W{}</b></span>",
				"weekdays": "<span color='#ffcc66'><b>{}</b></span>",
				"today": "<span color='#ff6699'><b><u>{}</u></b></span>"
			}
		},
		"format": "  {:%a %H:%M:%S}",
		"format-alt": "  {:%A, %d %B %Y}",
		"interval": 1
	},
	"cpu": {
		"format": " {usage}%",
		"on-click": "wezterm start -- btop",
		"tooltip": true,
		"interval": 5
	},
	"memory": {
		"format": " {}%",
		"on-click": "wezterm start -- btop",
		"tooltip-format": "{used:0.1f}G / {total:0.1f}G used",
		"interval": 5
	},
	"disk": {
		"interval": 30,
		"format": "󰋊 {percentage_used}%",
		"path": "/",
		"on-click": "wezterm start -- btop",
		"tooltip-format": "{used} / {total} used on {path}"
	},
	"network": {
		"format-wifi": "  {essid} ({signalStrength}%)",
		"format-ethernet": "󰈀 {ifname}",
		"format-disconnected": "󰖪 Disconnected",
		"on-click": "nm-connection-editor",
		"on-click-right": "bash -c 'if [ \"$(nmcli -t -f WIFI g)\" = enabled ]; then nmcli radio wifi off; else nmcli radio wifi on; fi'",
		"tooltip-format-wifi": "  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
		"tooltip-format-ethernet": "󰈀 {ifname}\nIP: {ipaddr}\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
		"tooltip-format-disconnected": "Disconnected",
		"max-length": 30
	},
	"bluetooth": {
		"format": "󰂯 {status}",
		"format-connected": "󰂱 {device_alias}",
		"format-connected-battery": "󰂱 {device_alias} {device_battery_percentage}%",
		"format-disabled": "󰂲",
		"format-off": "󰂲",
		"on-click": "blueman-manager",
		"on-click-right": "rfkill toggle bluetooth",
		"format-no-controller": "",
		"tooltip-format": "{controller_alias}\n{num_connections} connected",
		"tooltip-format-connected": "{controller_alias}\n\n{device_enumerate}",
		"tooltip-format-enumerate-connected": "{device_alias}",
		"tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_battery_percentage}%"
	},
	"battery": {
		"states": {
			"warning": 30,
			"critical": 15
		},
		"format": "{icon} {capacity}%",
		"format-charging": "󰂄 {capacity}%",
		"format-plugged": "󰚥 {capacity}%",
		"format-alt": "{icon} {time}",
		"on-click": "wezterm start -- btop",
		"on-click-right": "~/.config/hypr/scripts/toggle-charge.sh",
		"format-icons": [
			"󰁺",
			"󰁻",
			"󰁽",
			"󰁿",
			"󰁹"
		],
		"tooltip-format": "{timeTo}\nPower: {power:.1f}W"
	},
	"pulseaudio": {
		"format": "{icon} {volume}%",
		"format-muted": "󰝟 muted",
		"format-icons": {
			"headphone": "󰋋",
			"default": [
				"󰕿",
				"󰖀",
				"󰕾"
			]
		},
		"on-click": "pavucontrol",
		"on-click-right": "pamixer -t"
	},
	"backlight": {
		"format": "{icon} {percent}%",
		"on-click": "brightnessctl set +5%",
		"on-click-right": "brightnessctl set 5%-",
		"on-click-middle": "brightnessctl set 50%",
		"format-icons": [
			"",
			"",
			"",
			"",
			"",
			"",
			"",
			"",
			""
		],
		"scroll-step": 5
	},
	"custom/notification": {
		"tooltip-format": "Left: Toggle notifications\nRight: Do not disturb",
		"format": "{icon}",
		"format-icons": {
			"notification": "󱅫",
			"none": "󰂚",
			"dnd-notification": "󱅫",
			"dnd-none": "󰂛",
			"inhibited-notification": "󱅫",
			"inhibited-none": "󰂚",
			"dnd-inhibited-notification": "󰂛",
			"dnd-inhibited-none": "󰂛"
		},
		"return-type": "json",
		"exec-if": "which swaync-client",
		"exec": "swaync-client -swb",
		"on-click": "swaync-client -t -sw",
		"on-click-right": "swaync-client -d -sw",
		"escape": true
	},
	"hyprland/language": {
		"format": "󰌌 {short}"
	},
	"tray": {
		"icon-size": 16,
		"spacing": 10
	},
	"custom/power": {
		"tooltip-format": "Left: power menu\nRight: lock screen",
		"on-click": "wlogout &",
		"on-click-right": "hyprlock",
		"format": "⏻"
	}
}
